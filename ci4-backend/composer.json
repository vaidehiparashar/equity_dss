{
    "name": "adminpanel/ci4-backend",
    "description": "AdminPanel CodeIgniter 4 Backend API",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
